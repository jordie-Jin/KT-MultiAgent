# ============================================================
#  환경변수 예시 (.env.example)
# ------------------------------------------------------------
#  사용법:
#    1) 이 파일을 복사해 .env 로 만든다
#         PowerShell : Copy-Item .env.example .env
#         cmd        : copy .env.example .env
#    2) 아래 값(특히 MYSQL_PASSWORD)을 자기 환경에 맞게 채운다
#    3) .env 는 git 에 커밋되지 않는다 (.gitignore 등록됨)
#
#  로딩 방식: build.gradle 의 me.paulschwarz:spring-dotenv 가
#  앱 기동 시 .env 를 자동으로 읽어 환경변수처럼 주입한다.
#  (의존성을 쓰지 않을 경우 → 맨 아래 "수동 로딩" 참고)
# ============================================================

# --- MySQL 접속 정보 (application.yaml 의 ${...} 로 주입) ---
MYSQL_USER=root
MYSQL_PASSWORD=changeme            # ← 로컬 MySQL root 비밀번호로 교체
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=log_analysis

# --- (선택) 전체 JDBC URL 을 직접 지정하고 싶을 때 ---
# 지정하면 위 HOST/PORT/DATABASE 조합 대신 이 값이 우선한다.
# SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/log_analysis?serverTimezone=Asia/Seoul&characterEncoding=UTF-8&useSSL=false&allowPublicKeyRetrieval=true

# --- (선택) 앱 실행 설정 ---
# SPRING_PROFILES_ACTIVE=local
# SERVER_PORT=8080

# ------------------------------------------------------------
#  수동 로딩 (spring-dotenv 미사용 시)
#    PowerShell:
#      Get-Content .env | ForEach-Object {
#        if ($_ -match '^\s*([^#][^=]+)=(.*)$') {
#          [Environment]::SetEnvironmentVariable($matches[1].Trim(), $matches[2].Trim())
#        }
#      }
#      .\gradlew.bat bootRun
# ------------------------------------------------------------
